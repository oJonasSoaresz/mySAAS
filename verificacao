// 1. Lógica para pular campos automaticamente
const inputs = document.querySelectorAll('.codigo-digito');

inputs.forEach((input, index) => {
    input.addEventListener('input', (e) => {
        if (e.target.value.length === 1 && index < inputs.length - 1) {
            inputs[index + 1].focus();
        }
    });
});

// 2. Lógica para enviar e verificar
const btnVerificar = document.getElementById('verificar');

btnVerificar.addEventListener('click', async () => {
    let codigoDigitado = "";
    inputs.forEach(input => codigoDigitado += input.value);
    const email = localStorage.getItem('email_usuario');

    const response = await fetch('/api/verificar-codigo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, codigoDigitado })
    });

    if (response.ok) {
        localStorage.removeItem('email_usuario');
        window.location.href = '/dashboard.html';
    } else {
        alert("Código incorreto ou expirado!");
    }
});
